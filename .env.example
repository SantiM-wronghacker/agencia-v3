# LLM — proveedor principal
LLM_PROVIDER=auto
# auto = elige según tarea | ollama | groq | gemini | mistral

# Ollama local (RTX 5060 Ti)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# APIs cloud (tier gratuito)
GROQ_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=

# Base de datos
DB_PATH=data/agencia.db

# Export de paquetes cliente
EXPORT_PATH=export/

# Servidor de licencias
LICENSE_SERVER_URL=http://localhost:8080
ADMIN_TOKEN=dev-token

# SMTP para envío de emails (send-link)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password

# Template de descarga para clientes
DOWNLOAD_LINK_TEMPLATE=https://tu-dominio.com/download?key={license_key}

#
